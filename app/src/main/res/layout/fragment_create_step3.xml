<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F8"
    android:padding="24dp">

    <ImageView
        android:id="@+id/backBtn"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/icon_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 제목 -->
    <TextView
        android:id="@+id/titleText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="어떤 여행을 하시나요?"
        android:textSize="29sp"
        android:textStyle="bold"
        android:fontFamily="@font/gmarketsansttfmedium"
        android:textColor="#111111"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/backBtn"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- 아이콘 그리드 -->
    <GridLayout
        android:id="@+id/iconGrid"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:columnCount="3"
        android:useDefaultMargins="true"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/titleText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/fishingBtn"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_columnWeight="1"
            android:scaleType="centerInside"
            android:src="@drawable/unselected_fishing"/>

        <ImageView
            android:id="@+id/golfBtn"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_columnWeight="1"
            android:scaleType="centerInside"
            android:src="@drawable/unselected_golf"/>

        <ImageView
            android:id="@+id/mountainBtn"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_columnWeight="1"
            android:scaleType="centerInside"
            android:src="@drawable/unselected_mountain"/>

        <ImageView
            android:id="@+id/photoBtn"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_columnWeight="1"
            android:scaleType="centerInside"
            android:src="@drawable/unselected_photo"/>

        <ImageView
            android:id="@+id/picnicBtn"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_columnWeight="1"
            android:scaleType="centerInside"
            android:src="@drawable/unselected_picnic"/>

        <ImageView
            android:id="@+id/skiBtn"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_columnWeight="1"
            android:scaleType="centerInside"
            android:src="@drawable/unselected_ski"/>

        <ImageView
            android:id="@+id/swimBtn"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_columnWeight="1"
            android:scaleType="centerInside"
            android:src="@drawable/unselected_swim"/>

        <ImageView
            android:id="@+id/trackingBtn"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_columnWeight="1"
            android:scaleType="centerInside"
            android:src="@drawable/unselected_tracking"/>

        <ImageView
            android:id="@+id/valleyBtn"
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_columnWeight="1"
            android:scaleType="centerInside"
            android:src="@drawable/unselected_valley"/>

    </GridLayout>

    <!-- 완료 버튼 -->
    <Button
        android:id="@+id/finishBtn"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:text="완료"
        android:fontFamily="@font/gmarketsansttfmedium"
        android:textSize="18sp"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/iconGrid"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>